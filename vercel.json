{
  "routes": [
    {
      "src": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "rap.skene.info"
        }
      ],
      "dest": "/rap/$1"
    },
    {
      "src": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "klubi.skene.info"
        }
      ],
      "dest": "/klubi/$1"
    },
    {
      "handle": "filesystem"
    }
  ]
}
